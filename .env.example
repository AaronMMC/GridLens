# Backend priority: Ollama (free, local) → Claude (paid) → Groq (free cloud)
# If Ollama is detected at runtime, it's used automatically — no config needed.

# Claude profiles — stored as JSON in a single env var
CLAUDE_PROFILES=[{"name": "Personal", "key": "", "model": "claude-sonnet-4-6"}]
ACTIVE_CLAUDE_PROFILE=0

# Other backends
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_OUTPUT=csv
MAX_RESOLUTION=2000
AUTO_FALLBACK=true