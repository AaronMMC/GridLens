# SpreadsheetScanner — example config
# Copy this file to .env (next to the .exe or in the project root) and fill in your keys.

# ── Claude (paid, best accuracy) ──────────────────────────────────────────────
# Multiple profiles are supported — managed inside the app via Settings.
CLAUDE_PROFILES=[{"name": "Personal", "key": "", "model": "claude-sonnet-4-6"}]
ACTIVE_CLAUDE_PROFILE=0

# ── Groq (free cloud tier) ────────────────────────────────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=

# ── Ollama (free, local, offline fallback) ────────────────────────────────────
# Install from https://ollama.com, then run: ollama pull qwen2.5vl:7b
OLLAMA_BASE_URL=http://localhost:11434

# ── Preferences ───────────────────────────────────────────────────────────────
DEFAULT_OUTPUT=csv
MAX_RESOLUTION=2000
AUTO_FALLBACK=true